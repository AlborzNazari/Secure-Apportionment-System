# ============================================================
# .env.example — Secure Apportionment System
# ============================================================
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed to version control.
#
#   cp .env.example .env
#
# Generate a secure ENCRYPTION_KEY with:
#   python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# ============================================================

# Flask environment: development | testing | production
FLASK_ENV=development

# AES-256-CBC encryption key (32 bytes, base64-encoded).
# config.py will warn loudly if this is still the placeholder value.
ENCRYPTION_KEY=0XR9BZnppPiAZLn/lB+43HZPpXZrYpV7JmN3/c298FU=

# Optional: override the default log level (INFO | DEBUG | WARNING | ERROR)
LOG_LEVEL=INFO
